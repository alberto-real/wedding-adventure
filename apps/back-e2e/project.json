{
  "name": "back-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "implicitDependencies": [
    "back"
  ],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{projectRoot}/test-output/jest/coverage"
      ],
      "options": {
        "jestConfig": "apps/back-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": [
        "back:build",
        "back:serve"
      ]
    }
  }
}
